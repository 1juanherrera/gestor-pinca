CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# JWT — generar con: openssl rand -hex 32
#--------------------------------------------------------------------
TOKEN_SECRET = CAMBIAR_POR_STRING_ALEATORIO_DE_64_CHARS

#--------------------------------------------------------------------
# DATABASE (CI4 auto-mapea estos al array $default de Database.php)
#--------------------------------------------------------------------
database.default.hostname = gestor-pinca-db
database.default.username = CAMBIAR_USUARIO_DB
database.default.password = CAMBIAR_PASSWORD_DB
database.default.database = gestorpincadb
database.default.port     = 3306

#--------------------------------------------------------------------
# DOCKER COMPOSE
#--------------------------------------------------------------------
DB_NAME          = gestorpincadb
DB_USER          = CAMBIAR_USUARIO_DB
DB_PASSWORD      = CAMBIAR_PASSWORD_DB
DB_ROOT_PASSWORD = CAMBIAR_PASSWORD_ROOT_DB

#--------------------------------------------------------------------
# CORS — URL del frontend en producción
# Desarrollo:   http://localhost:5173
# Producción:   https://app.tudominio.com
#--------------------------------------------------------------------
CORS_ALLOWED_ORIGIN = http://localhost:5173

#--------------------------------------------------------------------
# IA — Clasificación química para deduplicación de materias primas
# (módulo Sincronización → Sugerencias IA). Sin esta key, usar el modo
# offline: php spark sync:clasificar --offline
#--------------------------------------------------------------------
# Proveedor auto-detectado por la key presente. Opción A — Gemini (Google):
# GEMINI_API_KEY = AIza...
# GEMINI_MODEL   = gemini-2.0-flash
# Opción B — Claude (Anthropic):
# ANTHROPIC_API_KEY = sk-ant-...
# ANTHROPIC_MODEL   = claude-sonnet-4-6
